[
  {
    "id": "rule-validation-required-fields",
    "name": "Required Fields Validation",
    "description": "Validates that all required fields are present",
    "type": "validation",
    "precedence": 50,
    "priority": 100,
    "enabled": true,
    "condition": {
      "id": "cond-1",
      "operator": "OR",
      "conditions": [
        {
          "id": "cond-1-1",
          "field": "lead.businessName",
          "operator": "is_null",
          "value": true
        },
        {
          "id": "cond-1-2",
          "field": "lead.ownerName",
          "operator": "is_null",
          "value": true
        },
        {
          "id": "cond-1-3",
          "field": "lead.phone",
          "operator": "is_null",
          "value": true
        }
      ]
    },
    "actions": [
      {
        "type": "reject",
        "message": "Missing required fields"
      },
      {
        "type": "add_score",
        "field": "dataQuality",
        "score": -50
      }
    ],
    "tags": ["validation", "critical"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-scoring-high-revenue",
    "name": "High Revenue Bonus",
    "description": "Adds bonus score for high revenue businesses",
    "type": "scoring",
    "precedence": 40,
    "priority": 80,
    "enabled": true,
    "condition": {
      "id": "cond-2",
      "field": "lead.annualRevenue",
      "operator": ">=",
      "value": 1000000,
      "dataType": "number"
    },
    "actions": [
      {
        "type": "add_score",
        "field": "revenueBonus",
        "score": 20
      },
      {
        "type": "set_field",
        "field": "metadata.highRevenue",
        "value": true
      }
    ],
    "tags": ["scoring", "revenue"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-alert-ucc-stacking",
    "name": "UCC Stacking Alert",
    "description": "Alerts when multiple active UCC positions detected",
    "type": "alert",
    "precedence": 50,
    "priority": 90,
    "enabled": true,
    "condition": {
      "id": "cond-3",
      "field": "uccFilings.length",
      "operator": ">",
      "value": 2,
      "dataType": "number"
    },
    "actions": [
      {
        "type": "send_alert",
        "message": "High stacking risk - multiple UCC positions detected",
        "metadata": {
          "severity": "warning",
          "category": "risk"
        }
      },
      {
        "type": "multiply_score",
        "field": "riskScore",
        "score": 1.5
      }
    ],
    "tags": ["alert", "risk", "ucc"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-transform-phone-format",
    "name": "Phone Number Normalization",
    "description": "Normalizes phone numbers to standard format",
    "type": "transformation",
    "precedence": 30,
    "priority": 95,
    "enabled": true,
    "condition": {
      "id": "cond-4",
      "field": "lead.phone",
      "operator": "regex",
      "value": "^[\\d\\s\\-\\(\\)]+$"
    },
    "actions": [
      {
        "type": "transform",
        "field": "lead.phone",
        "value": "normalized_phone_placeholder"
      }
    ],
    "tags": ["transformation", "phone"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-enrichment-missing-industry",
    "name": "Industry Enrichment Trigger",
    "description": "Triggers enrichment when industry is missing",
    "type": "enrichment",
    "precedence": 30,
    "priority": 70,
    "enabled": true,
    "condition": {
      "id": "cond-5",
      "operator": "AND",
      "conditions": [
        {
          "id": "cond-5-1",
          "field": "lead.industry",
          "operator": "is_null",
          "value": true
        },
        {
          "id": "cond-5-2",
          "field": "lead.businessName",
          "operator": "is_not_null",
          "value": true
        }
      ]
    },
    "actions": [
      {
        "type": "enrich_data",
        "field": "enrichmentRequired",
        "value": true
      },
      {
        "type": "set_field",
        "field": "metadata.enrichmentPriority",
        "value": "high"
      }
    ],
    "tags": ["enrichment", "industry"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-scoring-fresh-lead",
    "name": "Fresh Lead Bonus",
    "description": "Adds bonus score for very fresh leads",
    "type": "scoring",
    "precedence": 40,
    "priority": 85,
    "enabled": true,
    "condition": {
      "id": "cond-6",
      "field": "lead.leadAge",
      "operator": "<=",
      "value": 7,
      "dataType": "number"
    },
    "actions": [
      {
        "type": "add_score",
        "field": "freshnessBonus",
        "score": 15
      }
    ],
    "tags": ["scoring", "freshness"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-validation-email-format",
    "name": "Email Format Validation",
    "description": "Validates email format",
    "type": "validation",
    "precedence": 50,
    "priority": 90,
    "enabled": true,
    "condition": {
      "id": "cond-7",
      "operator": "AND",
      "conditions": [
        {
          "id": "cond-7-1",
          "field": "lead.email",
          "operator": "is_not_null",
          "value": true
        },
        {
          "id": "cond-7-2",
          "field": "lead.email",
          "operator": "not_contains",
          "value": "@"
        }
      ]
    },
    "actions": [
      {
        "type": "set_field",
        "field": "validationErrors.email",
        "value": "Invalid email format"
      },
      {
        "type": "add_score",
        "field": "dataQuality",
        "score": -10
      }
    ],
    "tags": ["validation", "email"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-scoring-verified-contact",
    "name": "Verified Contact Bonus",
    "description": "Adds bonus for verified contact information",
    "type": "scoring",
    "precedence": 40,
    "priority": 75,
    "enabled": true,
    "condition": {
      "id": "cond-8",
      "operator": "AND",
      "conditions": [
        {
          "id": "cond-8-1",
          "field": "lead.emailVerificationStatus",
          "operator": "==",
          "value": "valid"
        },
        {
          "id": "cond-8-2",
          "field": "lead.phoneVerificationStatus",
          "operator": "==",
          "value": "valid"
        }
      ]
    },
    "actions": [
      {
        "type": "add_score",
        "field": "verificationBonus",
        "score": 25
      },
      {
        "type": "set_field",
        "field": "metadata.fullyVerified",
        "value": true
      }
    ],
    "tags": ["scoring", "verification"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-alert-low-credit",
    "name": "Low Credit Score Alert",
    "description": "Alerts for very low credit scores",
    "type": "alert",
    "precedence": 50,
    "priority": 85,
    "enabled": true,
    "condition": {
      "id": "cond-9",
      "operator": "AND",
      "conditions": [
        {
          "id": "cond-9-1",
          "field": "lead.creditScore",
          "operator": "is_not_null",
          "value": true
        },
        {
          "id": "cond-9-2",
          "field": "lead.creditScore",
          "operator": "<",
          "value": 550,
          "dataType": "number"
        }
      ]
    },
    "actions": [
      {
        "type": "send_alert",
        "message": "Very low credit score detected - high risk",
        "metadata": {
          "severity": "warning",
          "category": "credit_risk"
        }
      },
      {
        "type": "add_score",
        "field": "riskScore",
        "score": 30
      }
    ],
    "tags": ["alert", "credit", "risk"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-transform-business-name",
    "name": "Business Name Standardization",
    "description": "Standardizes business name format",
    "type": "transformation",
    "precedence": 30,
    "priority": 90,
    "enabled": true,
    "condition": {
      "id": "cond-10",
      "field": "lead.businessName",
      "operator": "contains",
      "value": "LLC"
    },
    "actions": [
      {
        "type": "set_field",
        "field": "metadata.entityType",
        "value": "LLC"
      }
    ],
    "tags": ["transformation", "business"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-scoring-high-risk-industry",
    "name": "High Risk Industry Penalty",
    "description": "Applies penalty for high-risk industries",
    "type": "scoring",
    "precedence": 40,
    "priority": 88,
    "enabled": true,
    "condition": {
      "id": "cond-11",
      "field": "lead.industry",
      "operator": "in",
      "value": ["Restaurant", "Bar", "Nightclub", "Entertainment"]
    },
    "actions": [
      {
        "type": "add_score",
        "field": "industryRisk",
        "score": -20
      },
      {
        "type": "set_field",
        "field": "metadata.highRiskIndustry",
        "value": true
      }
    ],
    "tags": ["scoring", "industry", "risk"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  },
  {
    "id": "rule-enrichment-revenue-missing",
    "name": "Revenue Enrichment Trigger",
    "description": "Triggers revenue estimation when missing",
    "type": "enrichment",
    "precedence": 30,
    "priority": 85,
    "enabled": true,
    "condition": {
      "id": "cond-12",
      "operator": "AND",
      "conditions": [
        {
          "id": "cond-12-1",
          "field": "lead.annualRevenue",
          "operator": "is_null",
          "value": true
        },
        {
          "id": "cond-12-2",
          "field": "lead.estimatedRevenue",
          "operator": "is_null",
          "value": true
        }
      ]
    },
    "actions": [
      {
        "type": "enrich_data",
        "field": "revenueEstimationRequired",
        "value": true
      },
      {
        "type": "set_field",
        "field": "metadata.dataCompleteness",
        "value": "incomplete"
      }
    ],
    "tags": ["enrichment", "revenue"],
    "createdAt": "2024-01-01T00:00:00Z",
    "updatedAt": "2024-01-01T00:00:00Z",
    "version": 1
  }
]